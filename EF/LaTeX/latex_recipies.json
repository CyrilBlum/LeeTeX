  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.latex.clean.fileTypes": [
    "aux",
    "log",
    "out",
    "toc",
    "lof",
    "lot",
    "glo",
    "idx",
    "fls",
    "fdb_latexmk",
    "synctex.gz"
  ],
  "latex-workshop.latex.outDir": "./build",
  "latex-workshop.latex.rootFile.useSubFile": true,
  "latex-workshop.latex.rootFile.doNotPrompt": true,
  "latex-workshop.latex.tools": [
    {
      "name": "biber",
      "command": "biber",
      "args": [
        "--input-directory=build",
        "--output-directory=build",
        "%DOCFILE%"
      ],
      "env": {}
    },
    {
      "name": "makeglossaries",
      "command": "makeglossaries",
      "args": [
        "-d",
        "build",
        "%DOCFILE%"
      ]
    },
    {
      "name": "makeglossaries-lite",
      "command": "makeglossaries-lite",
      "args": [
        "%DOCFILE%"
      ]
    },
    {
      "name": "lualatex",
      "command": "lualatex",
      "args": [
        "--output-directory=build",
        "--interaction=nonstopmode",
        "--synctex=1",
        "%DOC%"
      ]
    },
    {
      "name": "pdflatex",
      "command": "pdflatex",
      "args": [
        "--interaction=nonstopmode",
        "--synctex=1",
        "--output-directory=build",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "lualatex",
      "tools": [
        "lualatex"
      ]
    },
    {
      "name": "lualatex -> lualatex",
      "tools": [
        "lualatex",
        "lualatex"
      ]
    },
    {
      "name": "lualatex -> biber -> lualatex x 2",
      "tools": [
        "lualatex",
        "biber",
        "lualatex",
        "lualatex"
      ]
    },
    {
      "name": "lualatex -> biber -> makeglossaries -> lualatex x 2",
      "tools": [
        "lualatex",
        "biber",
        "makeglossaries",
        "lualatex",
        "lualatex"
      ]
    },
    {
      "name": "pdflatex",
      "tools": [
        "pdflatex"
      ]
    }
  ]