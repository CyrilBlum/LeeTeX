\begin{frame}[fragile]{Zusammenfassung: Klassen}
	\begin{itemize}[<+->]
		\item Klasse = Bauplan für Objekt dessen \textbf{Attribute} und \textbf{Methoden} wir selber bestimmen
		\item \textbf{\_\_init\_\_} = Konstruktor der Klasse: wird automatisch aufgerufen, wenn ein neues Objekt erstellt wird.
		\item \textbf{self}: Instanzvariale - repräsentiert das konkrete Objekt mit dem gerade gearbeitet wird \rightarrow  muss immer der erste Parameter jeder Methode innerhalb einer Klasse sein
		\item \textbf{Attribute definieren}: Innerhalb der Klasse werden Attribute für ein Objekt mit self.attributname = wert erstellt
		\item \textbf{Auf Attribute zugreifen}: Um den Wert eines Attributs innerhalb einer Methode zu lesen/ ändern, wird ebenfalls self.attributname verwendet.
		\item \textbf{Methoden aufrufen}: Nachdem ein Objekt erstellt wurde, können seine Methoden mit der Punkt-Notation aufgerufen werden.
	\end{itemize}
\end{frame}