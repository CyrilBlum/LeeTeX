\begin{frame}[fragile]{\texttt{f}-Strings}
  \begin{itemize}
    \item \texttt{f}-Strings sind eine bequeme Methode, um Variablen oder Ausdrücke direkt in einen Text einzubauen.
  \end{itemize}
  \begin{lstlisting}[basicstyle=\ttfamily\scriptsize, numbers=left, framerule=1pt]
	name = "Ali"
	age = 17
	print(f"Mein Name ist {name} und ich bin {age} Jahre alt.")  
	# Ausgabe: Mein Name ist Ali und ich bin 17 Jahre alt.
  \end{lstlisting}
\end{frame}

\begin{frame}[fragile]{\texttt{f}-Strings}
  \begin{itemize}
    \item \texttt{f}-Strings sind eine bequeme Methode, um Variablen oder Ausdrücke direkt in einen Text einzubauen.
