\begin{frame}{Authentifizierung}
    Wir wollen uns heute besonders mit der Frage beschäftigen, wie Authentifizierung im Internet funktioniert.\\
    \begin{myexercise}
        \begin{itemize}
            \item Wie funktioniert Authentifizierung in der nicht-digitalen Welt?
            \item Wie kann man dieses Verfahren auf die digitale Welt, insbesondere das Internet, übertragen?
        \end{itemize}
    \end{myexercise}
\end{frame}

\begin{frame}{Zertifizierungsstelle}
    \begin{itemize}[<+->]
        \item Im Internet gibt es ähnlich den Ausweisdokumenten \textbf{SSL/ TLS Zertifikate}. Ein solches Zertifikat bestätigt, dass Sie mit \textbf{genau der Domain sprechen}, die in der Adressleiste steht.
        \item Ein solches Zertifikat wird von einer \textbf{Zertifizierungsstelle} (meist Certificate Authority (CA) genannt) ausgestellt.
        \item CAs unterliegen extrem strikten Kontrollen, welche sicherstellen, dass sie keine falschen Zertifikate ausstellen.
    \end{itemize}
\end{frame}

\begin{frame}{Zertifikatsausstellung}
    \begin{itemize}
        \item Woher weiss die CA, wann sie ein Zertifikat ausstellen darf?
        \item Häufigste Art der Validierung: \textbf{Domain Validation}: Hierbei zertifiziert die CA, dass der Antragsteller die Kontrolle über den Webserver hat.
    \end{itemize}
\end{frame}

