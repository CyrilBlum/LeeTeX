\begin{frame}{Zusammenfassung}
    \begin{itemize}[<+->]
        \item Aus den \textbf{Gefahren} im Internet (MitM, Sniffing, Tampering) ergeben sich drei \textbf{Sicherheitsziele}: \textbf{Vertraulichkeit}, \textbf{Integrität} und \textbf{Authentifizierung}.
        \item Als "Ausweis" für Webseiten im Internet dienen \textbf{SSL/TLS-Zertifikate}.
        \item Diese Zertifikate werden von vertrauenswürdigen \textbf{Zertifizierungsstellen (CAs)} ausgestellt.
        \item Die Echtheit der Zertifikate wird durch \textbf{asymmetrische Kryptografie} (digitale Signaturen) sichergestellt.
        \item Das HTTPS Protokoll stellt Vertraulichkait, Intefrität und Authentifizierung im Internet sicher.
    \end{itemize}
\end{frame}
