\begin{frame}{Echtheit des Zertifikats}
    \begin{itemize}[<+->]
        \item Wie kann unser Browser ein Zertifikat validieren?
        \item Die öffentlichen Schlüssel der CAs sind schon in unserem OS oder Webbrowser abgespeichert. $\rightarrow$ Damit können wir die Signatur der CA validieren. 
        \item URL im Zertifikat spricht mit des Servers überein
        \item Zertifikat ist gültig (nicht agbelaufen)
    \end{itemize}
\end{frame}

