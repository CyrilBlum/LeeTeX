\begin{frame}{Asymmetrische Kryptographie}
	\begin{itemize}[<+->]
		\item Ein Kryptosystem, in dem man den selben Schlüssel zur Verschlüsselung wie zur Entschlüsselung verwendet, heisst \textbf{symmetrisch}. 
        \item Bei einem \textbf{asymmetrischen Kryptosystem} werden verschiedene Schlüssel zur Ver- und Entschlüsselung verwendet.
		\begin{itemize}
			\item \textbf{Öffentlicher Schlüssel \emoji{unlock}} wird zum Verschlüsseln verwendet
			\item \textbf{Privater Schlüssel \emoji{key}} wird zum Entschlüsseln verwendet
		\end{itemize}
	\end{itemize}

\end{frame}

