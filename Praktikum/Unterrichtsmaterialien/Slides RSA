\begin{frame}{Zusammenfassung}
	\begin{itemize}[<+->]
		\item \textbf{Asymmetrische Kryptosystem} Verwenden einen öffentlichen Schlüssel zum verschlüsseln und einen privaten Schlüssel zum entschlüsseln.
		\item Die Schwierigkeit, asymmetrische Kryptosysteme zu knacken, liegt dadrin, dass es schwieig ist, die \textbf{Inverse} der Verschlüsselungsfunktion zu bestimmen.
		\item \textbf{RSA} Beispiel für ein asymmetrisches Kryptosystem
	\end{itemize}
\end{frame}