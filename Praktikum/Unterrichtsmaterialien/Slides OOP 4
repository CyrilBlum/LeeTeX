\begin{frame}[fragile]{Rückblick Vererbung}
	\begin{itemize}
		\item \textbf{Vererbung} ermöglicht es, eine neue Klasse basierend auf einer vorhandenen Klasse zu erstellen und deren Eigenschaften und Methoden zu übernehmen.\pause
	\end{itemize}
	\lstinputlisting[language=Python,caption=\texttt{tier.py},label=listing:tier, basicstyle=\tiny,]{Praktikum/Unterrichtsmaterialien/Code/elektroauto.py}\pause
	\begin{itemize}
        \item In der Vererbung erbt die Kindklasse alle Attribute und Methoden der Elternklasse. Dafür brauchen wir die Methoden nicht explizit zu wiederholen. Auch der Konstruktor wird vererbt.
    \end{itemize}
\end{frame}

\begin{frame}{Polymorphismus}
	\begin{itemize}
		\item Per default erbt die Kindklasse alle Attribute und Methoden der Elternklasse.\pause
		\item Manchmal möchten wir aber, dass die Methoden der Kindklasse ein anderes Ergebnis haben als die der Elternklasse. \pause
		\item\textbf{Polymorphismus} ermöglicht es, dass verschiedene Klassen auf die gleiche Weise angesprochen werden können, obwohl sich die Methoden unterscheiden.\pause
	\end{itemize}\pause
	\lstinputlisting[language=Python,caption=\texttt{polymorphismus.py},label=listing:polymorphismus, basicstyle=\tiny,]{Praktikum/Unterrichtsmaterialien/Code/polymorphism.py}
\end{frame}

\begin{frame}{Polymorphismus}
	Wir haben zwei \textbf{Möglichkeiten,} die Methoden der Elternklasse mittels Polymorphismus in der Kindklasse anzupassen:
	\begin{enumerate}
		\item <2-> \textbf{Überschreiben}: Wenn wir in der Kindklasse eine Methode mit \textbf{demselben Namen} wie die Elternklasse implementieren, so \textbf{ersetzt} diese die Implementierung der Elternklasse.
		\item <3-> \textbf{Erweitern}: Innerhalb der überschriebenen Methode in der Unterklasse können wir die \textbf{ursprüngliche Methode der Elternklasse aufrufen}, um deren Funktionalität zu nutzen, bevor oder nachdem wir neue Logik hinzufügen.\\\pause $\rightarrow$ Dazu verwenden wir super().methodenname(argumente)
	\end{enumerate}
\end{frame}

\begin{frame}[fragile]{Beispiel Polymorphismus}
	\begin{lstlisting}[basicstyle=\ttfamily\tiny, escapechar=!, numbers=left,framerule=1pt]
		class Tier:
			def __init__(self, name):
				self.name = name
				print(f"Tier '{self.name}' wurde erstellt.")

			def geraeusch(self):
				return f"{self.name} (Tier) macht ein Geräusch"

		class Hund(Tier):
			def __init__(self, name, rasse): !\tikzmark{comment1start}!				!\tikzmark{comment1end}!
				super().__init__(name) 
				self.rasse = rasse
				print(f"Hund '{self.name}' ist von Rasse '{self.rasse}'.")

			def geraeusch(self): !\tikzmark{comment2start}!						!\tikzmark{comment2end}!
				return "Wuff"

		class Katze(Tier):
			def geraeusch(self): !\tikzmark{comment3start}!						!\tikzmark{comment3end}!
				return "Miau"

		tiere = [Tier("Unbekanntes Tier"), Hund("Bello", "Golden Retriever"), Katze("Mieze")]

		for tier in tiere:
			print(f"{tier.name}: {tier.geraeusch()}")

		# Ausgabe:
		# Tier 'Unbekanntes Tier' wurde erstellt.
		# Tier 'Bello' wurde erstellt.
		# Hund 'Bello' ist von Rasse 'Golden Retriever'.
		# Tier 'Mieze' wurde erstellt.
		# Unbekanntes Tier: Unbekanntes Tier (Tier) macht ein Geräusch
		# Bello: Wuff
		# Mieze: Miau
	\end{lstlisting}

