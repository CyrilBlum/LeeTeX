\begin{frame}[fragile]{Attribute und Vererbung}
	\begin{itemize}
		\item Eine Kindklasse erbt automatisch alle Instanz- und Klassenattribute der Elternklasse.
		\item Beim Lesen wird der Wert aus der nächsthöheren Klasse im Vererbungsbaum verwendet, die dieses Attribut definiert.
	\end{itemize}
	\begin{lstlisting}[basicstyle=\ttfamily\tiny, numbers=left, framerule=1pt]
		class Fahrzeug:
			anzahl_raeder = 4
			typ = "Transportmittel" 

		class Auto(Fahrzeug):
			motorisiert = True
		
			def __init__(self, farbe):
				self.farbe = farbe

		mein_auto = Auto("Rot")

		# Attribut in der Kindklasse selbst gefunden
		print(f"Auto.motorisiert: {mein_auto.motorisiert}") # Ausgabe: Auto.motorisiert: True

		# Das gesuchte Attribut ist NICHT in der Kindklasse definiert!
		print(f"Auto.anzahl_raeder: {mein_auto.anzahl_raeder}")	# Ausgabe: Auto.anzahl_raeder: 4
	\end{lstlisting}
\end{frame}

\begin{frame}[fragile]{Attribute und Vererbung}
	\begin{itemize}
		\item Eine Kindklasse erbt automatisch alle Instanz- und Klassenattribute der Elternklasse.
		\item Beim Lesen wird der Wert aus der nächsthöheren Klasse im Vererbungsbaum verwendet, die dieses Attribut definiert.
		\item Wenn die Kindklasse ein Klassenattribut mit \textbf{demselben Namen} neu definiert (überschattet), erhält die Kindklasse ihre eigene Kopie dieses Attributs. \\ $\rightarrow$ Dies hat keine Auswirkung auf die Elternklasse.
	\end{itemize}
	\begin{lstlisting}[basicstyle=\ttfamily\tiny, numbers=left, framerule=1pt]
		class Fahrzeug:
    		anzahl_sitze = 5 # Elternwert

		class Sportwagen(Fahrzeug):
			anzahl_sitze = 2 # Kindklasse überschattet den Wert

		print(f"Sportwagen.anzahl_sitze: {Sportwagen.anzahl_sitze}") # 2
		print(f"Fahrzeug.anzahl_sitze: {Fahrzeug.anzahl_sitze}")     # 5 (Unverändert)
	\end{lstlisting}
\end{frame}

\begin{frame}{Getarntes Teilen}
	\begin{itemize}
		\item [\emoji{warning}] Wenn das Klassenattribut ein \textbf{veränderbarer Typ} (z. B. eine list oder ein dict) ist und die Kindklasse es \textbf{nicht überschattet} (d. h. nicht neu definiert), teilen sie sich dasselbe Objekt im Speicher.\pause
	\end{itemize}
\end{frame}

\begin{frame}[fragile]{Beispiel getarntes Teilen}
	\begin{lstlisting}[basicstyle=\ttfamily\tiny, numbers=left, framerule=1pt]
		class Schulklasse:
			# Mutable Klassenattribut (Liste)
			essensplan = ["Montag: Pizza", "Dienstag: Pasta"] 
			standard_getraenk = "Wasser" 

		class KlasseA(Schulklasse):
			@classmethod
			def tag_hinzufuegen(cls, tag_mahlzeit):
				cls.essensplan.append(tag_mahlzeit) 

		class KlasseB(Schulklasse):
			@classmethod
			def tag_hinzufuegen(cls, tag_mahlzeit):
				cls.essensplan.append(tag_mahlzeit) 
				
		KlasseA = Schulklasse()
		KlasseB = Schulklasse()
		KlasseA.tag_hinzufuegen("Mittwoch: Burger")
		KlasseB.tag_hinzufuegen("Mittwoch: Gemüsepfanne")

		print(f"Klasse A Plan: {KlasseA.essensplan}")
		# Ausgabe: ['Montag: Pizza', 'Dienstag: Pasta', 'Mittwoch: Burger', 'Mittwoch: Gemüsepfanne']
		print(f"Schulklasse Plan: {Schulklasse.essensplan}")
		# Ausgabe: ['Montag: Pizza', 'Dienstag: Pasta', 'Mittwoch: Burger', 'Mittwoch: Gemüsepfanne']

		KlasseA.standard_getraenk = "Apfelsaft"
		print(f"Klasse A Getränk: {KlasseA.standard_getraenk}") # Apfelsaft
		print(f"Schulklasse Getränk: {Schulklasse.standard_getraenk}") # Wasser
	\end{lstlisting}
\end{frame}

\begin{frame}{Getarntes Teilen}
	\begin{itemize}
		\item [\emoji{warning}] Wenn das Klassenattribut ein \textbf{veränderbarer Typ} (z. B. eine list oder ein dict) ist und die Kindklasse es \textbf{nicht überschattet} (d. h. nicht neu definiert), teilen sie sich dasselbe Objekt im Speicher.\pause
		\item \textbf{Verhalten}: Eine Änderung des Attributs in der Kindklasse wirkt sich auf die Elternklasse aus. \\ $\rightarrow$ Die Elternklasse wird unbeabsichtigt modifiziert \pause
		\item Um dies zu vermeiden, müssen wir das Attribut in der Kindklasse \textbf{explizit neu definieren}, wenn Sie es ändern möchten.
	\end{itemize}
\end{frame}

