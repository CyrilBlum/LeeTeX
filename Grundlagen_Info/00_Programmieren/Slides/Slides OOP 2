\begin{frame}[fragile]{Zusammenfassung}
	\begin{itemize}[<+->]
		\item Klassenattribute erlauben uns Attribute zu definieren, welche für alle Instanzen der Klasse gleich sind.
		\item Vererbung ermöglicht es, eine neue Klasse basierend auf einer vorhandenen Klasse zu erstellen und deren Eigenschaften und Methoden zu übernehmen.
	\end{itemize}
\end{frame}
