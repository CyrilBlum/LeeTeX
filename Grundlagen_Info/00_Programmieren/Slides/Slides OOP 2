\begin{frame}[fragile]{Klassenattribute Beispiel}
  	\begin{lstlisting}[basicstyle=\ttfamily\tiny, numbers=left, framerule=1pt]
		class Schueler:
    		schule = "Kantonsschule im Lee"  # Klassenattribut
			anzahl_schueler = 0

			def __init__(self, name, klasse):
				self.name = name  # Instanzattribut
				self.klasse = klasse  # Instanzattribut
				Schueler.anzahl_schueler += 1 # Verändert Klassenattribut
			
			def info(self):
				return f"{self.name}, Klasse {self.klasse}, {self.schule}"
			
			@classmethod
			def get_anzahl_schueler(cls):
				return print(f"Anzahl Schüler insgesamt: {cls.anzahl_schueler}")

		lisa = Schueler("Lisa", "3a")
		tim = Schueler("Tim", "4b")

		print(lisa.info())  # Lisa, Klasse 3a, Kantonsschule im Lee

		# Klassenattribut über die Klasse ändern
		Schueler.schule = "KLW"

		Schueler.get_anzahl_schueler() # Anzahl Schüler insgesamt: 2

		print(lisa.info())  # Lisa, Klasse 3a, KLW
		print(tim.info())  # Tim, Klasse 4b, KLW
	\end{lstlisting}
\end{frame}

\begin{frame}{Klassenattribute}
	\begin{itemize}
		\item Bisher: Attribute wurden für jedes Objekt der Klasse im Konstruktor initaliziert. Alle Attribute konnten für jedes Objekt verschieden sein. $\rightarrow$ \textbf{Instanzattribute}
		\item Man kann auch Attribute definieren, die für alle Instanzen der Klasse gleich sind. $\rightarrow$ \textbf{Klassenattribute}
	\end{itemize}
\end{frame}

