\begin{frame}[fragile]{Vererbung Beispiel}
	\begin{lstlisting}[basicstyle=\ttfamily\scriptsize, escapechar=!, numbers=left,framerule=1pt]
		class Fahrzeug:
			def __init__(self, marke, baujahr):
				self.marke = marke
				self.baujahr = baujahr
				self.geschwindigkeit = 0

			def beschleunigen(self, delta):
				self.geschwindigkeit += delta
				print(f"{self.marke} beschleunigt. Neue Geschwindigkeit: {self.geschwindigkeit} km/h.")

		class Auto(Fahrzeug):!\tikzmark{comment1start}!				!\tikzmark{comment1end}!
			def __init__(self, marke, baujahr, anzahl_tueren):
				super().__init__(marke, baujahr) !\tikzmark{comment2start}!					!\tikzmark{comment2end}!
				self.anzahl_tueren = anzahl_tueren !\tikzmark{comment3start}!			!\tikzmark{comment3end}!
			
			def hupen(self): !\tikzmark{comment4start}!				!\tikzmark{comment4end}!
				print(f"Das {self.marke} hupt laut!")

		mein_auto = Auto("BMW", 2022, 5)
		mein_auto.beschleunigen(30) !# Ausgabe: BMW beschleunigt. Neue Geschwindigkeit: 30 km/h.!

		mein_auto.hupen() !# Ausgabe: Das BMW hupt laut!!

		print(f"Anzahl Türen: {mein_auto.anzahl_tueren}, Baujahr: {mein_auto.baujahr}")
	\end{lstlisting}

